<Window x:Class="task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансовый менеджер" Height="450" Width="800">

    <Window.Resources>
        <ControlTemplate x:Key="AddButtonTemplate" TargetType="Button">
            <Border Background="LightBlue" CornerRadius="10">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <DataTemplate x:Key="TransactionTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Date, StringFormat=dd.MM.yyyy HH:mm}" />
                <TextBlock Text="{Binding Category}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Amount, StringFormat={}{0} руб.}"/>
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddIncomeCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding AddExpenseCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Транзакции">
                <MenuItem Header="Добавить доход (Ctrl+N)" Command="{Binding AddIncomeCommand}"/>
                <MenuItem Header="Добавить расход (Ctrl+E)" Command="{Binding AddExpenseCommand}"/>
                <Separator/>
                <MenuItem Header="Удалить (Del)" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="Помощь"/>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddIncomeCommand}" ToolTip="Добавить доход"
                    Template="{StaticResource AddButtonTemplate}" Margin="2" Padding="8,4">
                <TextBlock Text="Доход"/>
            </Button>
            <Button Command="{Binding AddExpenseCommand}" ToolTip="Добавить расход"
                    Template="{StaticResource AddButtonTemplate}" Margin="2" Padding="8,4">
                <TextBlock Text="Расход"/>
            </Button>
            <Separator/>
            <Button Command="{Binding DeleteCommand}" ToolTip="Удалить выбранное">
                <TextBlock Text="Удалить"/>
            </Button>
        </ToolBar>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Balance, StringFormat=Итоговый баланс: {0} руб.}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Фильтр по дате:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FilterDate, Mode=TwoWay}" Width="160"/>
                <Button Content="Сбросить" Command="{Binding ClearFilterCommand}" Margin="8,0,0,0"/>
            </StackPanel>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding FilteredTransactions}"
                      SelectedItem="{Binding SelectedTransaction}"
                      AutoGenerateColumns="True" CanUserAddRows="False"/>


            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Сумма выбранной операции:"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="120"
                         Text="{Binding SelectedTransaction.Amount, Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding SelectedTransaction,
                                     Converter={StaticResource NullToBoolConverter}}"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>