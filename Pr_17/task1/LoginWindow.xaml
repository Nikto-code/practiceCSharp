<Window x:Class="task1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="250" Width="350">
    <StackPanel Margin="20">
        <TextBlock Text="Имя пользователя:" FontWeight="Bold"/>
        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,5,0,10"/>
        <TextBlock Text="Пароль:" FontWeight="Bold"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,5,0,15"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Войти" Command="{Binding LoginCommand}"
                    Width="100" Margin="5" Click="OnPasswordCapture"/>
            <Button Content="Регистрация" Command="{Binding RegisterCommand}"
                    Width="100" Margin="5" Click="OnPasswordCapture"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusMessage}" Foreground="Red"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </StackPanel>
</Window>