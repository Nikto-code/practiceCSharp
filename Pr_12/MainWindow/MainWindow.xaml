<Window x:Class="FinanceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MainWindow"
        mc:Ignorable="d"
Title="Финансы" Height="400" Width="600">

    <StackPanel>

        <TextBlock x:Name="BalanceText" FontSize="16" Margin="10"/>

        <TabControl>

            <TabItem Header="Доходы">
                <StackPanel>
                    <DataGrid x:Name="IncomeGrid" AutoGenerateColumns="True" Height="150"/>
                    <Button Content="Добавить доход" Click="AddIncome_Click"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Расходы">
                <StackPanel>
                    <DataGrid x:Name="ExpenseGrid" AutoGenerateColumns="True" Height="150"/>
                    <Button Content="Добавить расход" Click="AddExpense_Click"/>
                </StackPanel>
            </TabItem>

        </TabControl>

    </StackPanel>
</Window>