<Window x:Class="z1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансы" Height="450" Width="700">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddTransactionCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteTransactionCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Транзакции">
                <MenuItem Header="Добавить" Command="{Binding AddTransactionCommand}"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteTransactionCommand}"/>
            </MenuItem>
            <MenuItem Header="Отчёты"/>
            <MenuItem Header="Настройки"/>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Content="Добавить" Command="{Binding AddTransactionCommand}"/>
            <Button Content="Удалить" Command="{Binding DeleteTransactionCommand}"/>
        </ToolBar>

        <StackPanel>

            <TextBlock Text="{Binding Balance, StringFormat=Баланс: {0}}"
                       FontSize="16" Margin="10"/>

            <DataGrid ItemsSource="{Binding Transactions}"
                      SelectedItem="{Binding SelectedTransaction}"
                      AutoGenerateColumns="True"
                      Height="250"/>

        </StackPanel>

    </DockPanel>
</Window>