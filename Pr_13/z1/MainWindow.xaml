<Window x:Class="z1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансовый менеджер" Height="450" Width="800">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddIncomeCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding AddExpenseCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Транзакции">
                <MenuItem Header="Добавить доход (Ctrl+N)" Command="{Binding AddIncomeCommand}"/>
                <MenuItem Header="Добавить расход (Ctrl+E)" Command="{Binding AddExpenseCommand}"/>
                <Separator/>
                <MenuItem Header="Удалить (Del)" Command="{Binding DeleteCommand}"/>
            </MenuItem>
            <MenuItem Header="Помощь"/>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddIncomeCommand}" ToolTip="Добавить доход">
                <TextBlock Text="Доход"/>
            </Button>
            <Button Command="{Binding AddExpenseCommand}" ToolTip="Добавить расход">
                <TextBlock Text="Расход"/>
            </Button>
            <Separator/>
            <Button Command="{Binding DeleteCommand}" ToolTip="Удалить выбранное">
                <TextBlock Text="Удалить"/>
            </Button>
        </ToolBar>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Balance, StringFormat=Итоговый баланс: {0} руб.}" 
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}" 
                      SelectedItem="{Binding SelectedTransaction}" 
                      AutoGenerateColumns="True" CanUserAddRows="False"/>
        </Grid>
    </DockPanel>
</Window>