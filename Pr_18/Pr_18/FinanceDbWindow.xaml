<Window x:Class="task1.FinanceDbWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="База данных транзакций" Height="450" Width="700">
    <DockPanel Margin="10">

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Загрузить"
                    Command="{Binding LoadCommand}"
                    Padding="8,4" Margin="0,0,5,0"/>
            <Button Content="+ Доход"
                    Command="{Binding AddIncomeCommand}"
                    Padding="8,4" Margin="0,0,5,0"/>
            <Button Content="- Расход"
                    Command="{Binding AddExpenseCommand}"
                    Padding="8,4" Margin="0,0,5,0"/>
            <Button Content="Обновить"
                    Command="{Binding UpdateCommand}"
                    Padding="8,4" Margin="0,0,5,0"/>
            <Button Content="Удалить"
                    Command="{Binding DeleteCommand}"
                    Padding="8,4"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Margin="0,0,0,8"
                    Visibility="{Binding IsLoading,
                        Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar Width="200" Height="16" IsIndeterminate="True" Margin="0,0,8,0"/>
            <TextBlock Text="Загрузка из базы данных..."
                       Foreground="Gray" FontStyle="Italic" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Дата"     Binding="{Binding Date}"      Width="140"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Сумма"    Binding="{Binding Amount}"    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>