@model List<task1.Models.ShoppingItem>

@{
    ViewBag.Title = "Список покупок";
}

<h2>Список покупок</h2>

@if (ViewBag.Message != null)
{
    <div style="color: red; font-weight: bold; margin-bottom: 10px;">
        ⚠ @ViewBag.Message
    </div>
}

<a asp-action="Create" asp-controller="Shopping">+ Добавить товар</a>
<hr />


<h3> Нужно купить</h3>

@{
    var notBought = Model.Where(i => !i.IsBought).ToList();
}

@if (notBought.Count == 0)
{
    <p>Все товары куплены!</p>
}
else
{
    <table border="1" cellpadding="8">
        <tr>
            <th>Куплено</th>
            <th>Название</th>
            <th>Количество</th>
            <th>Действия</th>
        </tr>
        @foreach (var item in notBought)
        {
            <tr>
                <td>
                    <input type="checkbox"
                           onchange="location.href='@Url.Action("ToggleBought", "Shopping", new { id = item.Id })'" />
                </td>
                <td>@item.Name</td>
                <td>@item.Quantity</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id"> Удалить</a>
                </td>
            </tr>
        }
    </table>
}

<hr />

<h3> Куплено</h3>

@{
    var bought = Model.Where(i => i.IsBought).ToList();
}

@if (bought.Count == 0)
{
    <p>Пока ничего не куплено.</p>
}
else
{
    <table border="1" cellpadding="8">
        <tr>
            <th>Куплено</th>
            <th>Название</th>
            <th>Количество</th>
            <th>Действия</th>
        </tr>
        @foreach (var item in bought)
        {
            <tr>
                <td>
                    <input type="checkbox" checked
                           onchange="location.href='@Url.Action("ToggleBought", "Shopping", new { id = item.Id })'" />
                </td>
                <td><s>@item.Name</s></td>
                <td>@item.Quantity</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id"> Удалить</a>
                </td>
            </tr>
        }
    </table>
}