@model task1.Models.ShoppingItemViewModel

@{
    ViewBag.Title = "Добавить товар";
}

<h2>Добавить товар</h2>

<form asp-action="Add" asp-controller="Shopping" method="post">

    <p>
        <label asp-for="Name">Название:</label>
        <input asp-for="Name" />
        <span asp-validation-for="Name" style="color:red;"></span>
    </p>

    <p>
        <label asp-for="Quantity">Количество:</label>
        <input asp-for="Quantity" type="number" />
        <span asp-validation-for="Quantity" style="color:red;"></span>
    </p>

    <button type="submit">Добавить</button>

</form>

<br />
<a href="@Url.Action("Index", "Shopping")">← Назад к списку</a>